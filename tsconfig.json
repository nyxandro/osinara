{
  "compilerOptions": {
    "target": "ES2022",
    "allowImportingTsExtensions": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["agent/**/*.ts", "scripts/**/*.ts", "evals/**/*.ts", ".eve/**/*.d.ts"]
}
